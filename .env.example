SEARCH_ENGINE=tavily

# Without Travily Configuration
SEARCH_ENGINE=searxng

SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_SEARCH_PATH=/search
SEARXNG_TIMEOUT=30
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=auto
SEARXNG_SAFESEARCH=0

